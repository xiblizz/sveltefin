APP_NAME=SvelteFin

# Public URL the app is reached at (adapter-node needs it for CSRF/form
# actions when running behind a reverse proxy — docker-compose.yml + pangolin).
ORIGIN=https://sveltefin.example.com

# URL of the Jellyfin server, reachable from THIS server only (keep it off the internet)
JELLYFIN_URL=http://127.0.0.1:8096

# Secret used to encrypt session cookies (AES-256-GCM). Min 32 chars.
# Generate with: openssl rand -hex 32
SESSION_SECRET=

# Optional: Jellyseerr/Overseerr integration. Leave empty to hide the Requests tab.
SEERR_URL=
SEERR_API_KEY=

# Optional: libmpv-wasm direct-play backend (src/lib/player/mpv/README.md).
# Requires the vendored wasm build in static/mpv/ and adds COOP/COEP headers
# (SharedArrayBuffer), which constrain embedding cross-origin resources.
ENABLE_MPV_BACKEND=1